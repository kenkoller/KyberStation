{
  "name": "@kyberstation/engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint: placeholder — eslint not yet configured'",
    "clean": "rm -rf dist",
    "gif:pickers": "tsx scripts/generate-picker-gifs.mjs",
    "bench:template-eval": "node --import=./perf/registerLoader.mjs perf/templateEvalBench.mjs"
  },
  "dependencies": {
    "@kyberstation/template-eval": "workspace:*",
    "peggy": "^4.2.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
