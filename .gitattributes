# Force consistent line endings across Mac and Windows
* text=auto eol=lf

# Windows scripts keep Windows endings
*.bat text eol=crlf
*.ps1 text eol=crlf
*.cmd text eol=crlf

# Binary files — don't touch these
*.png binary
*.jpg binary
*.ico binary
*.tiff binary
*.tif binary
*.woff binary
*.woff2 binary
*.wav binary
*.mp3 binary
*.ogg binary
